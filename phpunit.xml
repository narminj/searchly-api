<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_KEY" value="base64:2fl+Ktvkfl+Fuz4Qp/A75G2RTiWVA/ZoKZvp6fiiM10="/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <!-- database (not sync): a test that forgets Queue::fake() must never
             execute index jobs against a real Elasticsearch -->
        <env name="QUEUE_CONNECTION" value="database"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="ELASTICSEARCH_HOST" value="localhost:9200"/>
        <env name="ELASTICSEARCH_SSL_VERIFY" value="false"/>
        <env name="ELASTICSEARCH_PRODUCTS_INDEX" value="products_test"/>
        <!-- Exercise the multi-tenancy code paths in tests (production stays off
             until the data layer is migrated) -->
        <env name="MULTI_TENANCY_ENABLED" value="true"/>
    </php>
</phpunit>
