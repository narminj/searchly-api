APP_NAME=Searchly
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Laravel 12 reads CACHE_STORE (not CACHE_DRIVER). The unique job locks used by
# IndexProduct need a real store — database is the default and requires the
# cache_locks table (already migrated).
CACHE_STORE=database

# Async ES indexing runs through the queue; use database (or redis) — never sync
# in production, or every product write blocks on Elasticsearch. A worker must
# consume it: php artisan queue:work --queue=indexing,default
QUEUE_CONNECTION=database

# --- Elasticsearch -----------------------------------------------------------
# Host MUST include the scheme; the official client rejects a bare host:port.
ELASTICSEARCH_HOST=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_CLOUD_ID=
ELASTICSEARCH_RETRIES=2
ELASTICSEARCH_SSL_VERIFY=false
# Alias names — versioned physical indexes (products_v1, products_v2, …) sit
# behind these via elasticsearch:migrate.
ELASTICSEARCH_PRODUCTS_INDEX=products
ELASTICSEARCH_SEARCH_LOGS_INDEX=search_logs
# 0 for single-node dev (a 1-replica index stays yellow with no second node).
ELASTICSEARCH_REPLICAS=0
# Multi-tenancy is gated. Enable ONLY after migrating the DB and reindexing with
# tenant_id (see api/README §10) — turning it on first filters searches to zero.
MULTI_TENANCY_ENABLED=false

# SPA origin allowed by CORS (config/cors.php).
FRONTEND_URL=http://localhost:5173
